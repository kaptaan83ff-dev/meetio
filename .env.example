# --- App Config ---
APP_ENV=development
# Generate with: openssl rand -hex 32
SECRET_KEY=replace_with_64_char_hex_secret_key_at_least_64_chars_long_123456
FRONTEND_URL=http://localhost:5173

# --- Database ---
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/meetio
MONGODB_DB_NAME=meetio

# --- Cache & Pub/Sub ---
# Use rediss:// for Upstash (TLS)
REDIS_URL=redis://localhost:6379

# --- Authentication ---
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=240
JWT_REFRESH_TOKEN_EXPIRE_DAYS=15

# --- OAuth ---
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/v1/auth/google/callback

# --- Real-time Video (LiveKit) ---
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# --- Transcription (Deepgram) ---
DEEPGRAM_API_KEY=your_deepgram_api_key

# --- AI Recaps ---
AI_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# --- Storage (Cloudflare R2) ---
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=meetio-recordings
R2_PUBLIC_URL=https://recordings.your-app.com

# --- Email (Resend) ---
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=noreply@meetio.app

# --- Limits ---
MEETING_MAX_PARTICIPANTS=50
